flag = "reacted_to_prophet"

[node name="already_reacted" type="Node" parent="cond_talked/return_visit/cond_prophet/prophet_branch/cond_reacted_prophet" unique_id=1332564139]

[node name="say_prophet_short" type="Node" parent="cond_talked/return_visit/cond_prophet/prophet_branch/cond_reacted_prophet/already_reacted" unique_id=1718012227]
script = ExtResource("2_say")
speaker = 1
text = "Any prophecies about carrots? I really need a carrot day."

[node name="first_prophet" type="Node" parent="cond_talked/return_visit/cond_prophet/prophet_branch/cond_reacted_prophet" unique_id=1586416821]

[node name="say_prophet" type="Node" parent="cond_talked/return_visit/cond_prophet/prophet_branch/cond_reacted_prophet/first_prophet" unique_id=1321875884]
script = ExtResource("2_say")
speaker = 1
text = "Wait, you're a [i]prophet[/i]? Can you tell me if the stew will be ready by noon? ...It's just water. It's always ready."

[node name="say_pigeon_stew" type="Node" parent="cond_talked/return_visit/cond_prophet/prophet_branch/cond_reacted_prophet/first_prophet" unique_id=421577028]
script = ExtResource("2_say")
text = "Yes, Bertram. The water is ready."

[node name="set_reacted_prophet" type="Node" parent="cond_talked/return_visit/cond_prophet/prophet_branch/cond_reacted_prophet/first_prophet" unique_id=913030393]
