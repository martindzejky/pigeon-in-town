[node name="prophet_branch" type="Node" parent="cond_talked/return_visit/cond_prophet" unique_id=570333373]

[node name="cond_reacted_prophet" type="Node" parent="cond_talked/return_visit/cond_prophet/prophet_branch" unique_id=632422079]
