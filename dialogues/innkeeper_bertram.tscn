[node name="already_told" type="Node" parent="cond_talked/return_visit/cond_rumor/rumor_branch/cond_scared" unique_id=1060259735]

[node name="cond_done_panic" type="Node" parent="cond_talked/return_visit/cond_rumor/rumor_branch/cond_scared/already_told" unique_id=405351119]
script = ExtResource("5_condition")
flag = "done_ghost_panic"

[node name="repeat_panic" type="Node" parent="cond_talked/return_visit/cond_rumor/rumor_branch/cond_scared/already_told/cond_done_panic" unique_id=1401452303]

[node name="say_still_scared_short" type="Node" parent="cond_talked/return_visit/cond_rumor/rumor_branch/cond_scared/already_told/cond_done_panic/repeat_panic" unique_id=484643510]
script = ExtResource("2_say")
speaker = 1
text = "Still hearing noises. The garlic isn't working."

[node name="first_panic" type="Node" parent="cond_talked/return_visit/cond_rumor/rumor_branch/cond_scared/already_told/cond_done_panic" unique_id=2008698751]

[node name="say_still_scared" type="Node" parent="cond_talked/return_visit/cond_rumor/rumor_branch/cond_scared/already_told/cond_done_panic/first_panic" unique_id=460524701]
script = ExtResource("2_say")
speaker = 1
text = "I keep hearing noises from the graveyard. Or maybe it's the wind. Or maybe it's [color=#a8554c]GHOSTS[/color]. I can't sleep!"

[node name="say_pigeon_sleep" type="Node" parent="cond_talked/return_visit/cond_rumor/rumor_branch/cond_scared/already_told/cond_done_panic/first_panic" unique_id=1811095949]
script = ExtResource("2_say")
text = "You'll be fine, Bertram."

[node name="say_fine" type="Node" parent="cond_talked/return_visit/cond_rumor/rumor_branch/cond_scared/already_told/cond_done_panic/first_panic" unique_id=435138774]
script = ExtResource("2_say")
speaker = 1
text = "Easy for you to say! You can FLY away!"

[node name="set_done_panic" type="Node" parent="cond_talked/return_visit/cond_rumor/rumor_branch/cond_scared/already_told/cond_done_panic/first_panic" unique_id=2130103614]
script = ExtResource("6_set_flag")
flag = "done_ghost_panic"

[node name="not_told" type="Node" parent="cond_talked/return_visit/cond_rumor/rumor_branch/cond_scared" unique_id=1636766551]

[node name="choose_ghost" type="Node" parent="cond_talked/return_visit/cond_rumor/rumor_branch/cond_scared/not_told" unique_id=1945478925]
script = ExtResource("3_choose")

[node name="option_ghosts" type="Node" parent="cond_talked/return_visit/cond_rumor/rumor_branch/cond_scared/not_told/choose_ghost" unique_id=1341572365]
script = ExtResource("4_option")
label = "The graveyard is haunted"

[node name="say_pigeon_ghosts" type="Node" parent="cond_talked/return_visit/cond_rumor/rumor_branch/cond_scared/not_told/choose_ghost/option_ghosts" unique_id=1906381137]
script = ExtResource("2_say")
text = "You know the graveyard up by the church? It's haunted. Actual ghosts. I talked to them."

[node name="say_panic" type="Node" parent="cond_talked/return_visit/cond_rumor/rumor_branch/cond_scared/not_told/choose_ghost/option_ghosts" unique_id=1506460915]
script = ExtResource("2_say")
speaker = 1
text = "[shake rate=30.0 level=20]GHOSTS?![/shake] I KNEW the graveyard was too quiet! That's NOT normal quiet! That's [color=#a8554c]ghost quiet[/color]!"

[node name="say_pigeon_calm" type="Node" parent="cond_talked/return_visit/cond_rumor/rumor_branch/cond_scared/not_told/choose_ghost/option_ghosts" unique_id=2132863071]
script = ExtResource("2_say")
text = "They seemed pretty harmless."

[node name="say_no_harmless" type="Node" parent="cond_talked/return_visit/cond_rumor/rumor_branch/cond_scared/not_told/choose_ghost/option_ghosts" unique_id=1389387417]
script = ExtResource("2_say")
speaker = 1
text = "HARMLESS?! Ghosts are NEVER harmless! I'm putting garlic on the door! And the windows! And the stew! ...The stew already has nothing in it so garlic might help actually."

[node name="set_told_ghosts" type="Node" parent="cond_talked/return_visit/cond_rumor/rumor_branch/cond_scared/not_told/choose_ghost/option_ghosts" unique_id=1022698580]
script = ExtResource("6_set_flag")
flag = "told_about_ghosts"

[node name="set_scared" type="Node" parent="cond_talked/return_visit/cond_rumor/rumor_branch/cond_scared/not_told/choose_ghost/option_ghosts" unique_id=522711525]
script = ExtResource("6_set_flag")
flag = "g_someone_scared"
global = true

[node name="option_nevermind" type="Node" parent="cond_talked/return_visit/cond_rumor/rumor_branch/cond_scared/not_told/choose_ghost" unique_id=1831674287]
script = ExtResource("4_option")
label = "Never mind"

[node name="say_pigeon_nvm" type="Node" parent="cond_talked/return_visit/cond_rumor/rumor_branch/cond_scared/not_told/choose_ghost/option_nevermind" unique_id=536524632]
script = ExtResource("2_say")
text = "Actually, never mind. Forget I said anything."

[node name="say_ok" type="Node" parent="cond_talked/return_visit/cond_rumor/rumor_branch/cond_scared/not_told/choose_ghost/option_nevermind" unique_id=2094922621]
script = ExtResource("2_say")
speaker = 1
text = "Said what? I already forgot. ...What were we talking about?"

[node name="no_rumor" type="Node" parent="cond_talked/return_visit/cond_rumor" unique_id=2001706421]

[node name="say_bye" type="Node" parent="cond_talked/return_visit" unique_id=1831338724]
script = ExtResource("2_say")
speaker = 1
text = "Come back anytime! The stew is always... here. The stew is always here."

[node name="first_visit" type="Node" parent="cond_talked" unique_id=1820520479]

[node name="say_welcome" type="Node" parent="cond_talked/first_visit" unique_id=1921350771]
script = ExtResource("2_say")
speaker = 1
text = "Welcome to the tavern! Best stew in town! Well, [i]only[/i] stew in town. But still the best!"

[node name="say_pigeon_hi" type="Node" parent="cond_talked/first_visit" unique_id=373683308]
script = ExtResource("2_say")
text = "Thanks. What's in the stew?"

[node name="say_recipe" type="Node" parent="cond_talked/first_visit" unique_id=1744829554]
script = ExtResource("2_say")
speaker = 1
text = "Water! And sometimes a carrot. Today is a [color=#a8554c]no carrot[/color] day, though. So it's extra watery. Very smooth."

[node name="choose_stew" type="Node" parent="cond_talked/first_visit" unique_id=589389413]
script = ExtResource("3_choose")

[node name="option_water" type="Node" parent="cond_talked/first_visit/choose_stew" unique_id=320022119]
script = ExtResource("4_option")
label = "This is just water"

[node name="say_pigeon_water" type="Node" parent="cond_talked/first_visit/choose_stew/option_water" unique_id=1195370259]
script = ExtResource("2_say")
text = "Bertram, this is just warm water. There's nothing in it."

[node name="say_secret" type="Node" parent="cond_talked/first_visit/choose_stew/option_water" unique_id=1425361099]
script = ExtResource("2_say")
speaker = 1
text = "Water is the [i]secret ingredient[/i]. Most cooks use too much food. I figured out you don't need any!"

[node name="say_pigeon_genius" type="Node" parent="cond_talked/first_visit/choose_stew/option_water" unique_id=1520383470]
script = ExtResource("2_say")
text = "That's not how cooking works."

[node name="say_works" type="Node" parent="cond_talked/first_visit/choose_stew/option_water" unique_id=1124179304]
script = ExtResource("2_say")
speaker = 1
text = "Then why does everyone keep coming back? ...Nobody comes back. But they [i]could[/i]!"

[node name="set_criticized" type="Node" parent="cond_talked/first_visit/choose_stew/option_water" unique_id=1422414158]
script = ExtResource("6_set_flag")
flag = "criticized_stew"

[node name="option_great" type="Node" parent="cond_talked/first_visit/choose_stew" unique_id=2107445534]
script = ExtResource("4_option")
label = "Smells great!"

[node name="say_pigeon_great" type="Node" parent="cond_talked/first_visit/choose_stew/option_great" unique_id=782908714]
script = ExtResource("2_say")
text = "You know what? It smells great. Pour me another bowl."

[node name="say_happy" type="Node" parent="cond_talked/first_visit/choose_stew/option_great" unique_id=1179772852]
script = ExtResource("2_say")
speaker = 1
text = "A customer with [i]taste[/i]! Here, have a second bowl! Same water, fresh temperature!"

[node name="set_liked" type="Node" parent="cond_talked/first_visit/choose_stew/option_great" unique_id=1675540252]
script = ExtResource("6_set_flag")
flag = "liked_stew"

