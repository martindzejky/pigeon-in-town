[node name="return_visit" type="Node" parent="cond_talked" unique_id=554045072]

[node name="say_return" type="Node" parent="cond_talked/return_visit" unique_id=1718107842]
script = ExtResource("2_say")
speaker = 1
text = "You came [color=#a8554c]back[/color]! Nobody comes back! Oh, this is wonderful!"

[node name="cond_prophet" type="Node" parent="cond_talked/return_visit" unique_id=1874153282]
script = ExtResource("5_condition")
flag = "g_pigeon_is_prophet"
global = true

[node name="prophet_branch" type="Node" parent="cond_talked/return_visit/cond_prophet" unique_id=2082655485]

[node name="cond_reacted_prophet" type="Node" parent="cond_talked/return_visit/cond_prophet/prophet_branch" unique_id=31651710]
script = ExtResource("5_condition")
flag = "reacted_to_prophet"

[node name="already_reacted" type="Node" parent="cond_talked/return_visit/cond_prophet/prophet_branch/cond_reacted_prophet" unique_id=647483243]

[node name="say_prophet_short" type="Node" parent="cond_talked/return_visit/cond_prophet/prophet_branch/cond_reacted_prophet/already_reacted" unique_id=661001670]
script = ExtResource("2_say")
speaker = 1
text = "My knees still ache, by the way. That pigeon blessing hasn't kicked in yet."

[node name="first_prophet" type="Node" parent="cond_talked/return_visit/cond_prophet/prophet_branch/cond_reacted_prophet" unique_id=1678031554]

[node name="say_prophet" type="Node" parent="cond_talked/return_visit/cond_prophet/prophet_branch/cond_reacted_prophet/first_prophet" unique_id=387506437]
script = ExtResource("2_say")
speaker = 1
text = "Father Cuthbert says you're a [i]prophet[/i]! Can you bless my knees? They ache something terrible."

[node name="say_pigeon_knees" type="Node" parent="cond_talked/return_visit/cond_prophet/prophet_branch/cond_reacted_prophet/first_prophet" unique_id=735534663]
script = ExtResource("2_say")
text = "I don't think pigeon blessings work on knees."

[node name="say_worth_try" type="Node" parent="cond_talked/return_visit/cond_prophet/prophet_branch/cond_reacted_prophet/first_prophet" unique_id=871654852]
script = ExtResource("2_say")
speaker = 1
text = "Worth a try! Nothing else has worked. Not even the turnip poultice."

[node name="set_reacted_prophet" type="Node" parent="cond_talked/return_visit/cond_prophet/prophet_branch/cond_reacted_prophet/first_prophet" unique_id=1595184414]
script = ExtResource("6_set_flag")
flag = "reacted_to_prophet"

[node name="no_prophet" type="Node" parent="cond_talked/return_visit/cond_prophet" unique_id=331463382]

[node name="cond_ghost" type="Node" parent="cond_talked/return_visit" unique_id=508437598]
