[node name="already_reacted" type="Node" parent="cond_talked/return_visit/cond_ghost/ghost_branch/cond_reacted_ghost" unique_id=182794684]

[node name="say_ghost_short" type="Node" parent="cond_talked/return_visit/cond_ghost/ghost_branch/cond_reacted_ghost/already_reacted" unique_id=800651200]
script = ExtResource("2_say")
speaker = 1
text = "That graveyard still smells interesting. Ghosts or no ghosts."

[node name="first_ghost" type="Node" parent="cond_talked/return_visit/cond_ghost/ghost_branch/cond_reacted_ghost" unique_id=131335373]

[node name="say_ghost" type="Node" parent="cond_talked/return_visit/cond_ghost/ghost_branch/cond_reacted_ghost/first_ghost" unique_id=86979690]
script = ExtResource("2_say")
speaker = 1
text = "I heard there are [color=#a8554c]ghosts[/color] near the church! I don't care. Ghosts can't eat truffles. ...Can they?"

[node name="set_reacted_ghost" type="Node" parent="cond_talked/return_visit/cond_ghost/ghost_branch/cond_reacted_ghost/first_ghost" unique_id=1670588803]
script = ExtResource("6_set_flag")
flag = "reacted_to_ghost"

[node name="no_ghost" type="Node" parent="cond_talked/return_visit/cond_ghost" unique_id=1922940653]

[node name="first_visit" type="Node" parent="cond_talked" unique_id=1756629087]

[node name="say_sniff" type="Node" parent="cond_talked/first_visit" unique_id=547091177]
script = ExtResource("2_say")
speaker = 1
text = "Snff... snfff... I smell something. [i]Underground.[/i] Could be truffles. Could be a turnip. Could be a [color=#a8554c]body[/color]."

[node name="choose_react" type="Node" parent="cond_talked/first_visit" unique_id=119290604]
script = ExtResource("3_choose")

[node name="option_what" type="Node" parent="cond_talked/first_visit/choose_react" unique_id=2067503309]
script = ExtResource("4_option")
label = "What are you digging for?"

[node name="say_pigeon_what" type="Node" parent="cond_talked/first_visit/choose_react/option_what" unique_id=647838782]
script = ExtResource("2_say")
text = "What exactly are you digging for down there?"

[node name="say_everything" type="Node" parent="cond_talked/first_visit/choose_react/option_what" unique_id=1471942906]
script = ExtResource("2_say")
speaker = 1
text = "EVERYTHING! The ground is full of [i]secrets[/i]! And worms. Mostly worms. But sometimes secrets!"

[node name="say_pigeon_worms" type="Node" parent="cond_talked/first_visit/choose_react/option_what" unique_id=1502818859]
script = ExtResource("2_say")
text = "I like worms."

[node name="say_bonding" type="Node" parent="cond_talked/first_visit/choose_react/option_what" unique_id=847986302]
script = ExtResource("2_say")
speaker = 1
text = "See?! You get it! The ground provides for those who DIG!"

[node name="set_encouraged" type="Node" parent="cond_talked/first_visit/choose_react/option_what" unique_id=1593455054]
script = ExtResource("6_set_flag")
flag = "encouraged"

[node name="option_dont" type="Node" parent="cond_talked/first_visit/choose_react" unique_id=283658239]
script = ExtResource("4_option")
label = "Maybe don't dig there"

[node name="say_pigeon_dont" type="Node" parent="cond_talked/first_visit/choose_react/option_dont" unique_id=235132149]
script = ExtResource("2_say")
text = "Maybe you should stop digging. What if it really is a body?"

[node name="say_nose" type="Node" parent="cond_talked/first_visit/choose_react/option_dont" unique_id=1548921988]
script = ExtResource("2_say")
speaker = 1
text = "My nose says DIG. I trust my nose more than I trust [i]anything[/i]. My nose has never been wrong."

[node name="say_pigeon_never" type="Node" parent="cond_talked/first_visit/choose_react/option_dont" unique_id=1362491165]
script = ExtResource("2_say")
text = "Never?"

[node name="say_once" type="Node" parent="cond_talked/first_visit/choose_react/option_dont" unique_id=975368774]
script = ExtResource("2_say")
speaker = 1
text = "Well, once it said there were truffles and it was a rock. But it was a very [i]truffle-like[/i] rock."

