script = ExtResource("2_say")
speaker = 1
text = "Still digging. Still smells great down here. Snff."

[node name="first_return" type="Node" parent="cond_talked/return_visit/cond_done_return" unique_id=1655989589]

[node name="say_found" type="Node" parent="cond_talked/return_visit/cond_done_return/first_return" unique_id=1219865046]
script = ExtResource("2_say")
speaker = 1
text = "I found something near the [color=#a8554c]church[/color]! It smells like... soil and regret. And mushrooms. Lots of mushrooms."

[node name="say_pigeon_church" type="Node" parent="cond_talked/return_visit/cond_done_return/first_return" unique_id=461616799]
script = ExtResource("2_say")
text = "Near the church? That's close to the graveyard."

[node name="say_better" type="Node" parent="cond_talked/return_visit/cond_done_return/first_return" unique_id=1838869803]
script = ExtResource("2_say")
speaker = 1
text = "Even BETTER! Dead things make the best soil! And the best soil makes the best [i]truffles[/i]! It's the circle of life!"

[node name="say_pigeon_circle" type="Node" parent="cond_talked/return_visit/cond_done_return/first_return" unique_id=450196888]
script = ExtResource("2_say")
text = "That's... one way to look at it."

[node name="say_sniff_2" type="Node" parent="cond_talked/return_visit/cond_done_return/first_return" unique_id=1792577335]
script = ExtResource("2_say")
speaker = 1
text = "Snff... I can smell you too, by the way. You smell like breadcrumbs and [color=#6b8e5e]adventure[/color]."

[node name="say_pigeon_thanks" type="Node" parent="cond_talked/return_visit/cond_done_return/first_return" unique_id=2002456451]
script = ExtResource("2_say")
text = "Thanks. I think."

[node name="set_done_return" type="Node" parent="cond_talked/return_visit/cond_done_return/first_return" unique_id=1122918730]
