[node name="knight_first" type="Node" parent="cond_talked/first_visit" unique_id=1387193217]

[node name="say_shock_k" type="Node" parent="cond_talked/first_visit/knight_first" unique_id=1081082692]
script = ExtResource("2_say")
speaker = 1
text = "[shake rate=30.0 level=20]BY THE SAINTS![/shake] A [color=#a8554c]talking bird[/color]! AND you carry a knightly title?!"

[node name="say_pigeon_k" type="Node" parent="cond_talked/first_visit/knight_first" unique_id=2087790075]
script = ExtResource("2_say")
text = "A pig gave it to me. Long story."

[node name="say_holy_day" type="Node" parent="cond_talked/first_visit/knight_first" unique_id=691498485]
script = ExtResource("2_say")
speaker = 1
text = "A prophet [i]and[/i] a knight! The scrolls said nothing of this... but they [color=#a8554c]should[/color] have! I declare this a [color=#6b8e5e]holy day[/color]!"

[node name="say_pigeon_holy" type="Node" parent="cond_talked/first_visit/knight_first" unique_id=1256992373]
script = ExtResource("2_say")
text = "Does that mean free breadcrumbs?"

[node name="say_no_bread" type="Node" parent="cond_talked/first_visit/knight_first" unique_id=647932010]
script = ExtResource("2_say")
speaker = 1
text = "It means prayers! Which are better than breadcrumbs!"

[node name="say_pigeon_disagree" type="Node" parent="cond_talked/first_visit/knight_first" unique_id=1917260733]
script = ExtResource("2_say")
text = "They are really not."

