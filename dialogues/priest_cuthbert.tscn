[node name="knight_ending" type="Node" parent="cond_talked/return_visit/cond_knight_return" unique_id=491503923]

[node name="cond_reacted_knight" type="Node" parent="cond_talked/return_visit/cond_knight_return/knight_ending" unique_id=1921213289]
script = ExtResource("5_condition")
flag = "reacted_to_knight"

[node name="already_reacted_k" type="Node" parent="cond_talked/return_visit/cond_knight_return/knight_ending/cond_reacted_knight" unique_id=715411248]

[node name="say_knight_short" type="Node" parent="cond_talked/return_visit/cond_knight_return/knight_ending/cond_reacted_knight/already_reacted_k" unique_id=1808960358]
script = ExtResource("2_say")
speaker = 1
text = "Sir Prophet Pigeon! Still holy? Still knightly? Of course you are. Every day is a [color=#6b8e5e]holy day[/color]!"

[node name="first_knight" type="Node" parent="cond_talked/return_visit/cond_knight_return/knight_ending/cond_reacted_knight" unique_id=205457021]

[node name="say_return_knight" type="Node" parent="cond_talked/return_visit/cond_knight_return/knight_ending/cond_reacted_knight/first_knight" unique_id=975213073]
script = ExtResource("2_say")
speaker = 1
text = "Wait. You... you are a [color=#a8554c]knight[/color] now too?!"

[node name="say_pigeon_yep" type="Node" parent="cond_talked/return_visit/cond_knight_return/knight_ending/cond_reacted_knight/first_knight" unique_id=2035226272]
script = ExtResource("2_say")
text = "A pig in a pen knighted me. It was a whole ceremony."

[node name="say_holy_day_2" type="Node" parent="cond_talked/return_visit/cond_knight_return/knight_ending/cond_reacted_knight/first_knight" unique_id=513631556]
script = ExtResource("2_say")
speaker = 1
text = "A prophet [i]and[/i] a knight! The scrolls said nothing of this... but they [color=#a8554c]should[/color] have! I declare this a [color=#6b8e5e]holy day[/color]!"

[node name="say_pigeon_again" type="Node" parent="cond_talked/return_visit/cond_knight_return/knight_ending/cond_reacted_knight/first_knight" unique_id=1933010562]
script = ExtResource("2_say")
text = "You seem to declare a lot of holy days."

[node name="say_every_day" type="Node" parent="cond_talked/return_visit/cond_knight_return/knight_ending/cond_reacted_knight/first_knight" unique_id=240771044]
script = ExtResource("2_say")
speaker = 1
text = "Every day could be holy if you [i]believe[/i] hard enough!"

[node name="set_reacted_knight" type="Node" parent="cond_talked/return_visit/cond_knight_return/knight_ending/cond_reacted_knight/first_knight" unique_id=2031927056]
script = ExtResource("6_set_flag")
flag = "reacted_to_knight"

[node name="normal_return" type="Node" parent="cond_talked/return_visit/cond_knight_return" unique_id=916375599]

[node name="cond_blessed" type="Node" parent="cond_talked/return_visit/cond_knight_return/normal_return" unique_id=1372345545]
script = ExtResource("5_condition")
flag = "blessed_something"

[node name="already_blessed" type="Node" parent="cond_talked/return_visit/cond_knight_return/normal_return/cond_blessed" unique_id=1329431870]

[node name="cond_done_blessed" type="Node" parent="cond_talked/return_visit/cond_knight_return/normal_return/cond_blessed/already_blessed" unique_id=855636156]
script = ExtResource("5_condition")
flag = "done_blessed_return"

[node name="repeat_blessed" type="Node" parent="cond_talked/return_visit/cond_knight_return/normal_return/cond_blessed/already_blessed/cond_done_blessed" unique_id=1018523540]

[node name="say_blessed_short" type="Node" parent="cond_talked/return_visit/cond_knight_return/normal_return/cond_blessed/already_blessed/cond_done_blessed/repeat_blessed" unique_id=1937284649]
script = ExtResource("2_say")
speaker = 1
text = "The crops are still blessed! Or still rained on. Either way, praise be!"

[node name="first_blessed" type="Node" parent="cond_talked/return_visit/cond_knight_return/normal_return/cond_blessed/already_blessed/cond_done_blessed" unique_id=240450594]

[node name="say_blessed_return" type="Node" parent="cond_talked/return_visit/cond_knight_return/normal_return/cond_blessed/already_blessed/cond_done_blessed/first_blessed" unique_id=1579431182]
script = ExtResource("2_say")
speaker = 1
text = "The prophet graces us again! The crops have been growing better since your blessing. Or maybe it rained. Hard to tell."

[node name="say_pigeon_rain" type="Node" parent="cond_talked/return_visit/cond_knight_return/normal_return/cond_blessed/already_blessed/cond_done_blessed/first_blessed" unique_id=488214716]
script = ExtResource("2_say")
text = "Probably the rain."

[node name="say_faith" type="Node" parent="cond_talked/return_visit/cond_knight_return/normal_return/cond_blessed/already_blessed/cond_done_blessed/first_blessed" unique_id=1468570115]
script = ExtResource("2_say")
speaker = 1
text = "That's what a prophet would say!"

[node name="set_done_blessed" type="Node" parent="cond_talked/return_visit/cond_knight_return/normal_return/cond_blessed/already_blessed/cond_done_blessed/first_blessed" unique_id=1024780689]
script = ExtResource("6_set_flag")
flag = "done_blessed_return"

[node name="bless_branch" type="Node" parent="cond_talked/return_visit/cond_knight_return/normal_return/cond_blessed" unique_id=1604441393]

[node name="say_return_hello" type="Node" parent="cond_talked/return_visit/cond_knight_return/normal_return/cond_blessed/bless_branch" unique_id=1637950704]
script = ExtResource("2_say")
speaker = 1
text = "The prophet returns! Oh, what a blessed day! Could you... bless something for us?"

[node name="choose_bless" type="Node" parent="cond_talked/return_visit/cond_knight_return/normal_return/cond_blessed/bless_branch" unique_id=1041110042]
script = ExtResource("3_choose")

[node name="option_bless" type="Node" parent="cond_talked/return_visit/cond_knight_return/normal_return/cond_blessed/bless_branch/choose_bless" unique_id=1782973683]
script = ExtResource("4_option")
label = "Sure, I'll bless something"

[node name="say_pigeon_bless" type="Node" parent="cond_talked/return_visit/cond_knight_return/normal_return/cond_blessed/bless_branch/choose_bless/option_bless" unique_id=2042268502]
script = ExtResource("2_say")
text = "Fine. I bless this... ground. And that rock over there. You're all blessed."

[node name="say_bless_reply" type="Node" parent="cond_talked/return_visit/cond_knight_return/normal_return/cond_blessed/bless_branch/choose_bless/option_bless" unique_id=1757399552]
script = ExtResource("2_say")
speaker = 1
text = "[shake rate=30.0 level=20]MAGNIFICENT![/shake] Did you feel that? The air just got holier! I could weep!"

[node name="option_no_bless" type="Node" parent="cond_talked/return_visit/cond_knight_return/normal_return/cond_blessed/bless_branch/choose_bless" unique_id=1814036860]
script = ExtResource("4_option")
label = "I don't have that power"

[node name="say_pigeon_no" type="Node" parent="cond_talked/return_visit/cond_knight_return/normal_return/cond_blessed/bless_branch/choose_bless/option_no_bless" unique_id=1466941100]
script = ExtResource("2_say")
text = "I really don't think I can bless things. I'm a pigeon."

[node name="say_humble" type="Node" parent="cond_talked/return_visit/cond_knight_return/normal_return/cond_blessed/bless_branch/choose_bless/option_no_bless" unique_id=535791045]
script = ExtResource("2_say")
speaker = 1
text = "Such [i]humility[/i]! Truly divine! Only a real prophet would deny their own power!"

[node name="set_blessed" type="Node" parent="cond_talked/return_visit/cond_knight_return/normal_return/cond_blessed/bless_branch" unique_id=563161559]
script = ExtResource("6_set_flag")
flag = "blessed_something"

