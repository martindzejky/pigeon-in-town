[node name="normal_first" type="Node" parent="cond_talked/first_visit" unique_id=1978757067]

[node name="say_shock" type="Node" parent="cond_talked/first_visit/normal_first" unique_id=715468671]
script = ExtResource("2_say")
speaker = 1
text = "[shake rate=30.0 level=20]BY THE SAINTS![/shake] A [color=#a8554c]talking bird[/color]! The ancient scrolls foretold this!"

[node name="choose_react" type="Node" parent="cond_talked/first_visit/normal_first" unique_id=1510039728]
script = ExtResource("3_choose")

[node name="option_scrolls" type="Node" parent="cond_talked/first_visit/normal_first/choose_react" unique_id=312773604]
script = ExtResource("4_option")
label = "What scrolls?"

[node name="say_pigeon_scrolls" type="Node" parent="cond_talked/first_visit/normal_first/choose_react/option_scrolls" unique_id=643048933]
script = ExtResource("2_say")
text = "What scrolls? I just got here."

[node name="say_scrolls_reply" type="Node" parent="cond_talked/first_visit/normal_first/choose_react/option_scrolls" unique_id=1819019760]
script = ExtResource("2_say")
speaker = 1
text = "The scrolls! The ones I keep behind the altar! Well, it's mostly shopping lists. But one of them [i]definitely[/i] mentions a bird."

[node name="option_just_pigeon" type="Node" parent="cond_talked/first_visit/normal_first/choose_react" unique_id=1563063299]
script = ExtResource("4_option")
label = "I'm just a pigeon"

[node name="say_pigeon_normal" type="Node" parent="cond_talked/first_visit/normal_first/choose_react/option_just_pigeon" unique_id=2116164824]
script = ExtResource("2_say")
text = "I'm just a regular pigeon. Nothing special about me."

[node name="say_normal_reply" type="Node" parent="cond_talked/first_visit/normal_first/choose_react/option_just_pigeon" unique_id=1014429126]
script = ExtResource("2_say")
speaker = 1
text = "That is [i]exactly[/i] what the scroll says the divine messenger would say! Such humility!"

[node name="say_prophet" type="Node" parent="cond_talked/first_visit/normal_first" unique_id=1942333853]
script = ExtResource("2_say")
speaker = 1
text = "It is decided. You are the [color=#a8554c]feathered prophet[/color], sent to guide this village! I shall spread the word!"

[node name="say_pigeon_ok" type="Node" parent="cond_talked/first_visit/normal_first" unique_id=878841804]
script = ExtResource("2_say")
text = "I was looking for breadcrumbs, but sure."

