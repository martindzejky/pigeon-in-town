[node name="option_boring" type="Node" parent="cond_talked/return_visit/cond_friends/not_friends/cond_secret/secret_known/choose_return" unique_id=853974455]
script = ExtResource("4_option")
label = "Isn't this boring?"

[node name="say_pigeon_bored" type="Node" parent="cond_talked/return_visit/cond_friends/not_friends/cond_secret/secret_known/choose_return/option_boring" unique_id=828980885]
script = ExtResource("2_say")
text = "Don't you get bored? Just standing here all day?"

[node name="say_boring_reply" type="Node" parent="cond_talked/return_visit/cond_friends/not_friends/cond_secret/secret_known/choose_return/option_boring" unique_id=299487638]
script = ExtResource("2_say")
speaker = 1
text = "[shake rate=30.0 level=20]BORING?![/shake] Every day is life and death out here! One moment of weakness and the crows take EVERYTHING!"

[node name="option_agnes" type="Node" parent="cond_talked/return_visit/cond_friends/not_friends/cond_secret/secret_known/choose_return" unique_id=1149488979]
script = ExtResource("4_option")
label = "Agnes told me something..."

[node name="say_pigeon_agnes" type="Node" parent="cond_talked/return_visit/cond_friends/not_friends/cond_secret/secret_known/choose_return/option_agnes" unique_id=1470399982]
script = ExtResource("2_say")
text = "Agnes told me you've been standing here for thirty years. Alone."

[node name="say_quiet" type="Node" parent="cond_talked/return_visit/cond_friends/not_friends/cond_secret/secret_known/choose_return/option_agnes" unique_id=1797371380]
script = ExtResource("2_say")
speaker = 1
text = "..."

[node name="say_thirty" type="Node" parent="cond_talked/return_visit/cond_friends/not_friends/cond_secret/secret_known/choose_return/option_agnes" unique_id=1346875683]
script = ExtResource("2_say")
speaker = 1
text = "...Thirty years. Nobody's counted but her."

[node name="say_pigeon_long" type="Node" parent="cond_talked/return_visit/cond_friends/not_friends/cond_secret/secret_known/choose_return/option_agnes" unique_id=420139688]
script = ExtResource("2_say")
text = "That's a long time to stand alone."

[node name="say_it_is" type="Node" parent="cond_talked/return_visit/cond_friends/not_friends/cond_secret/secret_known/choose_return/option_agnes" unique_id=1537867209]
script = ExtResource("2_say")
speaker = 1
text = "...It is."

[node name="say_pause" type="Node" parent="cond_talked/return_visit/cond_friends/not_friends/cond_secret/secret_known/choose_return/option_agnes" unique_id=1809383979]
script = ExtResource("2_say")
speaker = 1
text = "You're alright. [color=#6b8e5e]For a bird.[/color]"

