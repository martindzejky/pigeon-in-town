[node name="option_compliment" type="Node" parent="cond_talked/return_visit/cond_friends/not_friends/cond_secret/secret_known/choose_return" unique_id=214158571]
script = ExtResource("4_option")
label = "You're doing a great job"

[node name="say_pigeon_good" type="Node" parent="cond_talked/return_visit/cond_friends/not_friends/cond_secret/secret_known/choose_return/option_compliment" unique_id=129628474]
script = ExtResource("2_say")
text = "I mean it. You're doing a really good job out here."

[node name="say_touched" type="Node" parent="cond_talked/return_visit/cond_friends/not_friends/cond_secret/secret_known/choose_return/option_compliment" unique_id=285742380]
script = ExtResource("2_say")
speaker = 1
text = "I... nobody has ever said that to me. Not once. ...Thank you."

[node name="set_complimented" type="Node" parent="cond_talked/return_visit/cond_friends/not_friends/cond_secret/secret_known/choose_return/option_compliment" unique_id=1241297528]
