[node name="first_visit" type="Node" parent="cond_talked" unique_id=1933876183]

[node name="say_scream" type="Node" parent="cond_talked/first_visit" unique_id=303590348]
script = ExtResource("2_say")
speaker = 1
text = "[shake rate=30.0 level=20]BIRD! BIRD IN THE FIELD![/shake] THIS IS A RESTRICTED AREA! LEAVE IMMEDIATELY!"

[node name="choose_react" type="Node" parent="cond_talked/first_visit" unique_id=1767889332]
script = ExtResource("3_choose")

[node name="option_pigeon" type="Node" parent="cond_talked/first_visit/choose_react" unique_id=1475695193]
script = ExtResource("4_option")
label = "I'm not a crow"

[node name="say_pigeon_not_crow" type="Node" parent="cond_talked/first_visit/choose_react/option_pigeon" unique_id=571805035]
script = ExtResource("2_say")
text = "Relax. I'm a pigeon, not a crow. I don't even like crops."

[node name="say_all_birds" type="Node" parent="cond_talked/first_visit/choose_react/option_pigeon" unique_id=1673286986]
script = ExtResource("2_say")
speaker = 1
text = "ALL birds are the enemy! I don't [i]discriminate[/i]! Pigeons, crows, sparrows, ducks. ALL OF THEM!"

[node name="option_peace" type="Node" parent="cond_talked/first_visit/choose_react" unique_id=963583218]
script = ExtResource("4_option")
label = "I come in peace"

[node name="say_pigeon_peace" type="Node" parent="cond_talked/first_visit/choose_react/option_peace" unique_id=1714759975]
script = ExtResource("2_say")
text = "Easy there. I come in peace. Not here for your crops."

[node name="say_sparrow" type="Node" parent="cond_talked/first_visit/choose_react/option_peace" unique_id=823380620]
script = ExtResource("2_say")
speaker = 1
text = "That's [i]exactly[/i] what the last sparrow said! And then he ate a seed! [shake rate=30.0 level=20]A SEED![/shake] Right in front of me!"

[node name="say_calm" type="Node" parent="cond_talked/first_visit" unique_id=1795985725]
script = ExtResource("2_say")
speaker = 1
text = "Fine. FINE. You can stay. But I'm [color=#a8554c]watching[/color] you. Don't touch the wheat."

[node name="say_pigeon_ok" type="Node" parent="cond_talked/first_visit" unique_id=737402135]
script = ExtResource("2_say")
text = "Wouldn't dream of it."

