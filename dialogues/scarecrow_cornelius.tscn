[node name="say_friend_return" type="Node" parent="cond_talked/return_visit/cond_friends/friends_branch" unique_id=911727730]
script = ExtResource("2_say")
speaker = 1
text = "Oh. It's you. ...Good."

[node name="say_pigeon_friend" type="Node" parent="cond_talked/return_visit/cond_friends/friends_branch" unique_id=1839916806]
script = ExtResource("2_say")
text = "Good to see you too, Cornelius."

[node name="say_nice" type="Node" parent="cond_talked/return_visit/cond_friends/friends_branch" unique_id=490337254]
script = ExtResource("2_say")
speaker = 1
text = "Don't make it weird. I still don't like birds. You're just... an exception."

[node name="not_friends" type="Node" parent="cond_talked/return_visit/cond_friends" unique_id=1871665365]

[node name="say_return_greet" type="Node" parent="cond_talked/return_visit/cond_friends/not_friends" unique_id=1296239819]
script = ExtResource("2_say")
speaker = 1
text = "Oh. You again. At least you haven't eaten any crops. ...Have you?"

[node name="say_pigeon_no" type="Node" parent="cond_talked/return_visit/cond_friends/not_friends" unique_id=490237520]
script = ExtResource("2_say")
text = "No. Still not interested in your crops."

